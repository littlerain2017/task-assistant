page {
  background: #080818;
}

.space-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.space-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.overlay-top {
  position: absolute;
  top: 100rpx;
  left: 0;
  right: 0;
  padding: 0 60rpx;
  z-index: 10;
}

.quote-text {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
  text-shadow: 0 0 40rpx rgba(150, 100, 255, 0.8);
}

.date-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

.overlay-bottom {
  position: absolute;
  bottom: 80rpx;
  left: 0;
  right: 0;
  padding: 0 48rpx;
  z-index: 10;
}

.stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 40rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx 0;
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #a78bfa;
}

.stat-num.done {
  color: #34d399;
}

.stat-num.pending {
  color: #fb923c;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.stat-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.1);
}

.mode-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  text-align: center;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.mode-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.mode-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 16rpx 32rpx;
  border-radius: 24rpx;
  backdrop-filter: blur(16px);
}

.mode-focus {
  background: linear-gradient(145deg, rgba(139, 92, 246, 0.35), rgba(109, 40, 217, 0.2));
  border: 1rpx solid rgba(167, 139, 250, 0.35);
}

.mode-scattered {
  background: linear-gradient(145deg, rgba(96, 165, 250, 0.28), rgba(16, 185, 129, 0.18));
  border: 1rpx solid rgba(96, 165, 250, 0.35);
}

.mode-icon {
  font-size: 56rpx;
  margin-bottom: 18rpx;
}

.mode-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 3rpx;
}

.mode-zh {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-top: 6rpx;
  margin-bottom: 14rpx;
}

.mode-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  text-align: center;
  line-height: 1.5;
}

.btn-progress {
  width: 100%;
  background: rgba(255, 255, 255, 0.07);
  color: rgba(255, 255, 255, 0.45);
  border-radius: 14rpx;
  font-size: 28rpx;
  padding: 22rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
