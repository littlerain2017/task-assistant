<view class="space-container">
  <canvas type="2d" id="spaceCanvas" class="space-canvas" bindtap="onTap" />

  <view class="overlay-top">
    <view class="quote-text">{{quote}}</view>
    <view class="date-text">{{today}}</view>
  </view>

  <view class="overlay-bottom">
    <view class="stats" wx:if="{{taskCount > 0}}">
      <view class="stat-item">
        <text class="stat-num">{{taskCount}}</text>
        <text class="stat-label">任务</text>
      </view>
      <view class="stat-divider" />
      <view class="stat-item">
        <text class="stat-num done">{{doneCount}}</text>
        <text class="stat-label">完成</text>
      </view>
      <view class="stat-divider" />
      <view class="stat-item">
        <text class="stat-num pending">{{taskCount - doneCount}}</text>
        <text class="stat-label">待办</text>
      </view>
    </view>

    <view class="mode-hint">今天，你想怎么工作？</view>

    <view class="mode-row">
      <view class="mode-card mode-focus" catchtap="goToFocus">
        <text class="mode-icon">⚡</text>
        <text class="mode-name">Focus</text>
        <text class="mode-zh">专注模式</text>
        <text class="mode-desc">有计划，逐步击破</text>
      </view>
      <view class="mode-card mode-scattered" catchtap="goToScattered">
        <text class="mode-icon">🌊</text>
        <text class="mode-name">Scattered</text>
        <text class="mode-zh">随机模式</text>
        <text class="mode-desc">打破僵局，随机开始</text>
      </view>
    </view>

    <button class="btn-progress" catchtap="goToProgress" wx:if="{{taskCount > 0}}">查看进度</button>
  </view>
</view>
