.hint {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 20rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f4f6f9;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.task-input {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  color: #1a1a1a;
}

.add-btn {
  font-size: 48rpx;
  color: #a78bfa;
  font-weight: 300;
  padding: 0 8rpx;
}

.goal-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goal-item:last-child { border-bottom: none; }

.goal-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.delete-btn {
  color: #ccc;
  font-size: 40rpx;
  padding: 0 8rpx;
}

.btn-random {
  width: 100%;
  margin-top: 32rpx;
  background: linear-gradient(135deg, #a78bfa, #60a5fa);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  border: none;
}

.btn-random[disabled] {
  opacity: 0.6;
}

.result-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.result-label {
  font-size: 26rpx;
  color: #a78bfa;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}

.result-step {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  line-height: 1.6;
  padding: 0 20rpx;
  margin-bottom: 40rpx;
}

.result-timer {
  font-size: 26rpx;
  color: #bbb;
  margin-bottom: 60rpx;
}

.result-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.btn-reroll {
  flex: 1;
  background: #f4f6f9;
  color: #666;
  border-radius: 14rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}

.btn-go {
  flex: 2;
  background: linear-gradient(135deg, #a78bfa, #60a5fa);
  color: #fff;
  border-radius: 14rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}
