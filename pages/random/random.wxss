page {
  background: #fffef8;
}

.scatter-container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.scatter-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* ── No-tasks state ── */
.no-tasks-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 254, 248, 0.96);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  padding: 60rpx;
  z-index: 5;
}

.no-tasks-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.no-tasks-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.no-tasks-hint {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.4);
  text-align: center;
  line-height: 1.6;
}

.btn-go-focus {
  margin-top: 24rpx;
  background: #080808;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  padding: 24rpx 64rpx;
  border: none;
}

/* ── Bottom selection panel ── */
.bottom-panel {
  position: absolute;
  bottom: 48rpx;
  left: 40rpx;
  right: 40rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  border-radius: 28rpx;
  padding: 32rpx 36rpx;
  backdrop-filter: blur(20px);
  z-index: 10;
}

.panel-task-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #0a0a0a;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.panel-hint {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.25);
  text-align: center;
  padding: 12rpx 0;
}

.btn-start {
  width: 100%;
  background: #080808;
  color: #fff;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 26rpx 0;
  border: none;
}

.btn-start[disabled] {
  opacity: 0.4;
}

/* ── Result view ── */
.result-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fffef8;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  z-index: 20;
}

.result-label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.4);
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
  align-self: flex-start;
}

.result-step {
  font-size: 40rpx;
  font-weight: 600;
  color: #0a0a0a;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.result-timer {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.25);
  margin-bottom: 60rpx;
}

.result-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.btn-reroll {
  flex: 1;
  background: rgba(0, 0, 0, 0.06);
  color: rgba(0, 0, 0, 0.5);
  border-radius: 999rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}

.btn-go {
  flex: 2;
  background: #080808;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  border: none;
}
