<view class="scatter-container">

  <canvas
    type="2d"
    id="scatterCanvas"
    class="scatter-canvas"
  />

  <!-- Bottom panel — always visible when no result -->
  <view wx:if="{{!result}}" class="bottom-panel">
    <view wx:if="{{!hasTasks}}" class="panel-hint">今天暂无任务，将从随机灵感中选一个</view>
    <button class="btn-start" bindtap="pickAndStart" disabled="{{loading}}">
      <text wx:if="{{!loading}}">让命运决定</text>
      <text wx:if="{{loading}}">正在拾取...</text>
    </button>
  </view>

  <!-- Result view -->
  <view wx:if="{{result}}" class="result-container">
    <view class="result-label">从「{{result.goal}}」开始</view>
    <view class="result-step">{{result.first_step}}</view>
    <view class="result-timer">30分钟后会来问你进展</view>
    <view class="result-actions">
      <button class="btn-reroll" bindtap="reroll">换一个</button>
      <button class="btn-go" bindtap="goStart">就这个，开始</button>
    </view>
  </view>

</view>
