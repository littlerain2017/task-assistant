<view class="container">

  <view class="card" wx:if="{{tasks.length === 0}}">
    <view class="empty-tip">今天还没有录入任务</view>
  </view>

  <view
    class="card task-card"
    wx:for="{{tasks}}"
    wx:key="index"
  >
    <view class="task-name">{{item.name}}</view>
    <view class="status-row">
      <view
        class="status-btn {{item.status === '未开始' ? 'gray' : ''}}"
        bindtap="setStatus"
        data-index="{{index}}"
        data-status="未开始"
      >未开始</view>
      <view
        class="status-btn {{item.status === '进行中' ? 'blue' : ''}}"
        bindtap="setStatus"
        data-index="{{index}}"
        data-status="进行中"
      >进行中</view>
      <view
        class="status-btn {{item.status === '已完成' ? 'green' : ''}}"
        bindtap="setStatus"
        data-index="{{index}}"
        data-status="已完成"
      >已完成</view>
    </view>
  </view>

  <button
    class="btn-primary"
    bindtap="submitProgress"
    wx:if="{{tasks.length > 0}}"
  >提交进度</button>

</view>
