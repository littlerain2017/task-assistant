.task-card {
  margin-bottom: 20rpx;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  flex: 1;
  margin-right: 20rpx;
}

.progress-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  min-width: 70rpx;
  text-align: right;
  transition: color 0.2s;
}

.progress-value.going {
  color: #1677ff;
}

.progress-value.done {
  color: #52c41a;
}

.slider {
  margin: 0 -10rpx;
}

.slider-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
  padding: 0 4rpx;
}

.date-header {
  font-size: 24rpx;
  color: #bbb;
  padding: 20rpx 0 8rpx;
  letter-spacing: 2rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}
