.task-card {
  margin-bottom: 20rpx;
}

.task-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.status-row {
  display: flex;
  gap: 16rpx;
}

.status-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  font-size: 26rpx;
  background: #f4f6f9;
  color: #999;
}

.status-btn.gray {
  background: #e8e8e8;
  color: #666;
  font-weight: 500;
}

.status-btn.blue {
  background: #e6f4ff;
  color: #1677ff;
  font-weight: 500;
}

.status-btn.green {
  background: #f6ffed;
  color: #52c41a;
  font-weight: 500;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}
