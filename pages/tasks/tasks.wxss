.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f4f6f9;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.task-input {
  flex: 1;
  font-size: 30rpx;
  padding: 24rpx 0;
  color: #1a1a1a;
}

.add-btn {
  font-size: 48rpx;
  color: #1677ff;
  font-weight: 300;
  padding: 0 8rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 12rpx;
}

.task-item:last-child {
  border-bottom: none;
}

.task-dot {
  color: #1677ff;
  font-size: 36rpx;
  line-height: 1;
}

.task-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.delete-btn {
  color: #ccc;
  font-size: 40rpx;
  padding: 0 8rpx;
}
